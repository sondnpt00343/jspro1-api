{
  "name": "jspro1-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "REST API for the JS Pro 1 blog project.",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/src/server.js",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "lint": "eslint .",
    "test": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:e2e:public": "vitest run tests/e2e/public-api.e2e.test.ts",
    "test:all": "npm run lint && npm run typecheck && npm run test && npm run test:integration",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed:compiled": "node dist/prisma/seed.js"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/cors": "^11.0.1",
    "@fastify/helmet": "^13.0.1",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/swagger": "^9.5.1",
    "@fastify/swagger-ui": "^5.2.3",
    "@prisma/client": "^6.10.1",
    "@sinclair/typebox": "^0.34.33",
    "argon2": "^0.43.0",
    "dotenv": "^16.5.0",
    "fastify": "^5.4.0",
    "prisma": "^6.10.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.29.0",
    "@types/node": "^24.0.1",
    "eslint": "^9.29.0",
    "globals": "^15.15.0",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.34.0",
    "vitest": "^3.2.4"
  }
}
