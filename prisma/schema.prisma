generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  active
  disabled

  @@map("user_status")
}

enum ThemePreference {
  system
  light
  dark

  @@map("theme_preference")
}

enum MediaKind {
  image

  @@map("media_kind")
}

enum PostStatus {
  draft
  published
  archived

  @@map("post_status")
}

enum PageStatus {
  draft
  published
  archived

  @@map("page_status")
}

enum NavigationLocation {
  header_primary
  header_secondary
  user_menu
  footer

  @@map("navigation_location")
}

enum NavigationAuthState {
  any
  guest
  authenticated

  @@map("navigation_auth_state")
}

enum ContactMessageStatus {
  new
  read
  replied
  archived

  @@map("contact_message_status")
}

model User {
  id                  String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                String
  email               String               @unique @db.Citext
  passwordHash        String               @map("password_hash")
  status              UserStatus           @default(active)
  createdAt           DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt           DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)
  profile             UserProfile?
  posts               Post[]
  mediaAssets         MediaAsset[]         @relation("MediaAssetCreatedBy")
  sessions            AuthSession[]
  passwordResetTokens PasswordResetToken[]

  @@map("users")
}

model UserProfile {
  userId          String          @id @map("user_id") @db.Uuid
  displayName     String          @map("display_name")
  headline        String?
  bio             String?
  avatarAssetId   String?         @map("avatar_asset_id") @db.Uuid
  themePreference ThemePreference @default(system) @map("theme_preference")
  createdAt       DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  avatar          MediaAsset?     @relation("UserProfileAvatar", fields: [avatarAssetId], references: [id], onDelete: SetNull)

  @@map("user_profiles")
}

model MediaAsset {
  id             String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  kind           MediaKind     @default(image)
  url            String
  altText        String        @default("") @map("alt_text")
  width          Int?
  height         Int?
  source         String?
  createdBy      String?       @map("created_by") @db.Uuid
  createdAt      DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6)
  creator        User?         @relation("MediaAssetCreatedBy", fields: [createdBy], references: [id], onDelete: SetNull)
  variants       MediaVariant[]
  profileAvatars UserProfile[] @relation("UserProfileAvatar")
  postCovers     Post[]        @relation("PostCover")
  heroSlides     HeroSlide[]   @relation("HeroSlideMedia")

  @@index([createdBy], map: "media_assets_created_by_idx")
  @@map("media_assets")
}

model MediaVariant {
  id         String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  assetId    String     @map("asset_id") @db.Uuid
  variantKey String     @map("variant_key")
  url        String
  width      Int
  height     Int
  createdAt  DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)
  asset      MediaAsset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@unique([assetId, variantKey])
  @@index([assetId, variantKey], map: "media_variants_asset_idx")
  @@map("media_variants")
}

model Category {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  slug        String   @unique
  description String?
  sortOrder   Int      @default(0) @map("sort_order")
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  posts       Post[]

  @@index([isActive, sortOrder, name], map: "categories_active_sort_idx")
  @@map("categories")
}

model Tag {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String
  slug        String    @unique
  description String?
  sortOrder   Int       @default(0) @map("sort_order")
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  posts       PostTag[]

  @@index([isActive, sortOrder, name], map: "tags_active_sort_idx")
  @@map("tags")
}

model Post {
  id              String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  authorId        String         @map("author_id") @db.Uuid
  categoryId      String         @map("category_id") @db.Uuid
  coverAssetId    String?        @map("cover_asset_id") @db.Uuid
  title           String
  slug            String         @unique
  excerpt         String?
  bodyHtml        String         @default("") @map("body_html")
  bodyJson        Json           @default("{}") @map("body_json")
  status          PostStatus     @default(draft)
  readMinutes     Int            @default(1) @map("read_minutes")
  seoTitle        String?        @map("seo_title")
  metaDescription String?        @map("meta_description")
  publishedAt     DateTime?      @map("published_at") @db.Timestamptz(6)
  createdAt       DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime       @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt       DateTime?      @map("deleted_at") @db.Timestamptz(6)
  author          User           @relation(fields: [authorId], references: [id], onDelete: Restrict)
  category        Category       @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  cover           MediaAsset?    @relation("PostCover", fields: [coverAssetId], references: [id], onDelete: SetNull)
  tags            PostTag[]
  relatedFrom     PostRelation[] @relation("PostRelatedFrom")
  relatedTo       PostRelation[] @relation("PostRelatedTo")

  @@index([authorId, status, updatedAt], map: "posts_author_status_updated_idx")
  @@index([categoryId, publishedAt], map: "posts_category_public_idx")
  @@map("posts")
}

model PostTag {
  postId String @map("post_id") @db.Uuid
  tagId  String @map("tag_id") @db.Uuid
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
  @@index([tagId], map: "post_tags_tag_idx")
  @@map("post_tags")
}

model PostRelation {
  postId        String @map("post_id") @db.Uuid
  relatedPostId String @map("related_post_id") @db.Uuid
  sortOrder     Int    @default(0) @map("sort_order")
  post          Post   @relation("PostRelatedFrom", fields: [postId], references: [id], onDelete: Cascade)
  relatedPost   Post   @relation("PostRelatedTo", fields: [relatedPostId], references: [id], onDelete: Cascade)

  @@id([postId, relatedPostId])
  @@index([postId, sortOrder], map: "post_relations_sort_idx")
  @@map("post_relations")
}

model Page {
  id              String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug            String      @unique
  title           String
  lead            String?
  bodyHtml        String      @default("") @map("body_html")
  seoTitle        String?     @map("seo_title")
  metaDescription String?     @map("meta_description")
  status          PageStatus  @default(published)
  createdAt       DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime    @updatedAt @map("updated_at") @db.Timestamptz(6)
  heroSlides      HeroSlide[]

  @@map("pages")
}

model HeroSlide {
  id           String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  pageId       String      @map("page_id") @db.Uuid
  title        String
  subtitle     String?
  linkUrl      String?     @map("link_url")
  mediaAssetId String?     @map("media_asset_id") @db.Uuid
  sortOrder    Int         @default(0) @map("sort_order")
  isActive     Boolean     @default(true) @map("is_active")
  createdAt    DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime    @updatedAt @map("updated_at") @db.Timestamptz(6)
  page         Page        @relation(fields: [pageId], references: [id], onDelete: Cascade)
  media        MediaAsset? @relation("HeroSlideMedia", fields: [mediaAssetId], references: [id], onDelete: SetNull)

  @@index([pageId, isActive, sortOrder], map: "hero_slides_page_sort_idx")
  @@map("hero_slides")
}

model NavigationItem {
  id        String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  location  NavigationLocation
  label     String
  href      String
  iconClass String?             @map("icon_class")
  authState NavigationAuthState @default(any) @map("auth_state")
  sortOrder Int                 @default(0) @map("sort_order")
  isActive  Boolean             @default(true) @map("is_active")
  createdAt DateTime            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime            @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([location, href, authState])
  @@index([location, authState, sortOrder], map: "navigation_items_location_sort_idx")
  @@map("navigation_items")
}

model SiteSetting {
  key       String   @id
  value     Json
  isPublic  Boolean  @default(true) @map("is_public")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("site_settings")
}

model ContactMessage {
  id        String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String
  email     String               @db.Citext
  message   String
  status    ContactMessageStatus @default(new)
  ipAddress String?              @map("ip_address") @db.Inet
  userAgent String?              @map("user_agent")
  createdAt DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime             @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([status, createdAt], map: "contact_messages_status_created_idx")
  @@map("contact_messages")
}

model AuthSession {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash")
  ipAddress String?   @map("ip_address") @db.Inet
  userAgent String?   @map("user_agent")
  expiresAt DateTime  @map("expires_at") @db.Timestamptz(6)
  revokedAt DateTime? @map("revoked_at") @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt], map: "auth_sessions_user_active_idx")
  @@map("auth_sessions")
}

model PasswordResetToken {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash")
  expiresAt DateTime  @map("expires_at") @db.Timestamptz(6)
  usedAt    DateTime? @map("used_at") @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt], map: "password_reset_tokens_user_idx")
  @@map("password_reset_tokens")
}
